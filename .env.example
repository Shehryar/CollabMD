# CollabMD environment variables
# Copy to apps/web/.env.local and fill in values

# ── Web App ──────────────────────────────────────────────
PORT=3000

# ── Auth (Better Auth) ──────────────────────────────────
# REQUIRED: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# ── Sync Server ─────────────────────────────────────────
# Public WebSocket URL (used by browser clients)
NEXT_PUBLIC_SYNC_URL=ws://localhost:4444

# Internal HTTP URL (Docker/prod only, server-to-server)
# SYNC_SERVER_INTERNAL_URL=http://sync-server:4444

# Snapshot interval in ms (default: 300000 = 5 min)
# SNAPSHOT_INTERVAL_MS=300000

# ── OAuth (optional, skip for magic-link-only local dev) ─
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Database ────────────────────────────────────────────
# Default: SQLite at apps/web/local.db (no config needed)
# For Postgres:
# DATABASE_URL=postgres://user:pass@localhost:5432/collabmd

# ── OpenFGA ─────────────────────────────────────────────
# Default: embedded local instance on :8081
# OPENFGA_URL=http://localhost:8081

# ── Email ───────────────────────────────────────────────
# Default: prints magic links to console in dev
# RESEND_API_KEY=

# ── Storage ─────────────────────────────────────────────
# Default: local filesystem
# S3_BUCKET=
# S3_REGION=
