# CollabMD environment variables
# Copy to apps/web/.env.local and fill in values

# Web app port (default: 3000)
PORT=3000

# Auth (Better Auth) -- REQUIRED
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# Sync server WebSocket URL (default: ws://localhost:4444)
NEXT_PUBLIC_SYNC_URL=ws://localhost:4444

# OAuth (optional, skip for magic-link-only local dev)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Database (default: SQLite for local dev)
# DATABASE_URL=postgres://user:pass@localhost:5432/collabmd

# OpenFGA (default: embedded local instance on :8081)
# OPENFGA_URL=http://localhost:8081

# Email (default: console output for local dev)
# RESEND_API_KEY=

# Storage (default: local filesystem)
# S3_BUCKET=
# S3_REGION=
