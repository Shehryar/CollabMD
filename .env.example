# CollabMD environment variables
# Copy to .env.local and fill in values

# Database (default: SQLite for local dev)
# DATABASE_URL=postgres://user:pass@localhost:5432/collabmd

# Auth (Better Auth)
# BETTER_AUTH_URL=http://localhost:3000
# BETTER_AUTH_SECRET=your-secret-here
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email (default: console output for local dev)
# RESEND_API_KEY=

# OpenFGA (default: embedded local instance)
# OPENFGA_API_URL=http://localhost:8081

# Sync server WebSocket URL (default: ws://localhost:4444)
# NEXT_PUBLIC_SYNC_URL=ws://localhost:4444

# Storage (default: local filesystem)
# S3_BUCKET=
# S3_REGION=
