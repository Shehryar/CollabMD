# CollabMD Production Environment
# Copy to .env.production and fill in values

# ── Domain ────────────────────────────────────────────────
# Your domain (used by Caddy for auto-TLS)
DOMAIN=collabmd.example.com

# ── Auth ──────────────────────────────────────────────────
# REQUIRED: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://collabmd.example.com

# ── Sync Server ──────────────────────────────────────────
# Public WebSocket URL (what browsers connect to)
# If using same domain with /sync path prefix:
NEXT_PUBLIC_SYNC_URL=wss://collabmd.example.com/sync
# If using subdomain:
# NEXT_PUBLIC_SYNC_URL=wss://sync.collabmd.example.com

# ── Database (Supabase) ──────────────────────────────────
# Connection string from Supabase dashboard → Settings → Database
# Use the "connection string" (not the pooler) for migrations
# Use the "connection pooler" URL for runtime if you expect many connections
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# OpenFGA can share the same Supabase Postgres instance
# or use a separate database. If sharing, create a separate schema.
OPENFGA_DATASTORE_URI=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Email (optional but recommended) ─────────────────────
# For magic link auth + notification emails
# Sign up at resend.com
RESEND_API_KEY=
