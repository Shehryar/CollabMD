{
  "name": "collabmd",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/collabmd/collabmd.git"
  },
  "homepage": "https://github.com/collabmd/collabmd",
  "bugs": {
    "url": "https://github.com/collabmd/collabmd/issues"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "tsx scripts/dev.ts",
    "dev:quick": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "queue": "tsx scripts/queue.ts",
    "queue:progress": "tsx scripts/queue.ts progress",
    "queue:run": "tsx scripts/queue.ts run",
    "queue:dry-run": "tsx scripts/queue.ts run --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "classic-level",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@collabmd/shared": "workspace:*",
    "commander": "^14.0.3"
  }
}
