{
  "name": "collabmd",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "tsx scripts/dev.ts",
    "dev:quick": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "classic-level",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@collabmd/shared": "workspace:*",
    "commander": "^14.0.3"
  }
}
