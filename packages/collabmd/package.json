{
  "name": "collabmd",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "collabmd": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/cli/index.ts src/index.ts --format esm --dts",
    "dev": "tsup src/cli/index.ts src/index.ts --format esm --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@collabmd/shared": "workspace:*",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "fast-diff": "^1.3.0",
    "lib0": "^0.2.117",
    "open": "^10.1.0",
    "ws": "^8.19.0",
    "y-leveldb": "^0.2.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.27.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.0.18"
  }
}
