{
  "name": "collabmd",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "collabmd": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/cli/index.ts src/index.ts --format esm --dts",
    "dev": "tsup src/cli/index.ts src/index.ts --format esm --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@collabmd/shared": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
